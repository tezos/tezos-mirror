# This contract uses TRANSFER_TOKENS in a view, which is forbidden.
# Adapted from proto_024 reference test (UNPAPAIR replaced with UNPAIR + DIP { UNPAIR }).
{
  storage unit ;
  parameter unit ;
  code {
         CAR ;
         NIL operation ;
         PAIR
  } ;
  view "v" (pair unit mutez (contract unit)) unit
    { CAR ; UNPAIR ; DIP { UNPAIR } ; TRANSFER_TOKENS ; DROP ; UNIT }
}
