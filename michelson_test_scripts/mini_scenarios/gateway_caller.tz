# Calls the TezosXGateway enshrined contract's %call_evm entrypoint.
# Storage: pair address (pair string (pair string bytes))
#   address     = gateway KT1
#   1st string  = EVM destination address
#   2nd string  = EVM method signature
#   bytes       = ABI-encoded parameters
parameter unit;
storage (pair address (pair string (pair string bytes)));
code {
       CDR;
       DUP;
       UNPAIR;
       CONTRACT %call_evm (pair string (pair string (pair bytes (option (contract bytes)))));
       ASSERT_SOME;
       # Rebuild parameter: wrap inner (string, bytes) into (string, (bytes, None))
       SWAP;
       UNPAIR; # dest : (pair string bytes) : (contract ...) : storage
       SWAP;
       UNPAIR; # method_sig : abi_params : dest : (contract ...) : storage
       SWAP;
       NONE (contract bytes);
       SWAP;
       PAIR;   # (pair abi_params None) : method_sig : dest : (contract ...) : storage
       SWAP;
       PAIR;   # (pair method_sig (pair abi_params None)) : dest : (contract ...) : storage
       SWAP;
       PAIR;   # (pair dest (pair method_sig (pair abi_params None))) : (contract ...) : storage
       AMOUNT;
       SWAP;
       TRANSFER_TOKENS;
       NIL operation;
       SWAP;
       CONS;
       PAIR
     };
