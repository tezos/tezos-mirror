parameter (or (unit %run) (or (bytes %on_result) (unit %_incrementWitness))) ;
storage (pair (nat %count)
              (pair (string %destination)
                    (pair (string %method_sig)
                          (pair (bytes %abi_params)
                                (option %result bytes))))) ;
# Michelson-to-EVM bridge with callback for CRAC test scenarios.
#
# Like cross_runtime_run_evm.tz, but passes Some(SELF %on_result) as
# callback to the gateway's %call_evm entrypoint, so the EVM return
# value is delivered back to this contract.
#
# Storage layout:
#   Pair (nat %count)
#        (Pair (string %destination)
#              (Pair (string %method_sig)
#                    (Pair (bytes %abi_params)
#                          (option %result bytes))))
#
# %run: emits [incr, gateway.call_evm(..., Some(SELF %on_result)), incr]
# %on_result(bytes): stores received bytes in %result, increments count
# %_incrementWitness: count++
#
# The gateway address (KT18oDJJKXMKhfE1bSuAPGp92pYcwVDiqsPw) is the
# enshrined CRAC contract with a deterministic address.
#
# Since this contract exposes %run, it can be composed with
# multi_run_caller.tz, multi_run_caller.sol and
# cross_runtime_run_tez.sol to build arbitrary cross-runtime
# call trees.
code
  { UNPAIR ;
    IF_LEFT
      { # run()
        DROP ;
        # Unpack storage fields
        DUP ; CDR ; CAR ;
        # destination : storage
        DIP { DUP ; CDR ; CDR ; CAR } ;
        # destination : method_sig : storage
        DIP 2 { DUP ; CDR ; CDR ; CDR ; CAR } ;
        # destination : method_sig : abi_params : storage
        # Build gateway call parameter:
        #   Pair destination (Pair method_sig (Pair abi_params (Some callback)))
        DIP 3
            { PUSH @gateway address "KT18oDJJKXMKhfE1bSuAPGp92pYcwVDiqsPw" ;
              CONTRACT %call_evm (pair string (pair string (pair bytes (option (contract bytes))))) ;
              ASSERT_SOME } ;
        # destination : method_sig : abi_params : (contract %call_evm ...) : storage
        DIP 2 { SELF %on_result ; SOME ; SWAP ; PAIR } ;
        # destination : method_sig : (pair abi_params (Some callback)) : (contract ...) : storage
        DIP { PAIR } ;
        # destination : (pair method_sig (pair abi_params (Some callback))) : (contract ...) : storage
        PAIR ;
        # param : (contract ...) : storage
        AMOUNT ; SWAP ;
        TRANSFER_TOKENS ;
        # gateway_op : storage
        # Build post-increment operation
        SELF %_incrementWitness ;
        PUSH mutez 0 ; UNIT ; TRANSFER_TOKENS ;
        # post_incr : gateway_op : storage
        # Build ops list: [gateway_op, post_incr]
        NIL operation ; SWAP ; CONS ; SWAP ; CONS ;
        # [gateway_op, post_incr] : storage
        # Build pre-increment operation
        SELF %_incrementWitness ;
        PUSH mutez 0 ; UNIT ; TRANSFER_TOKENS ;
        # pre_incr : [gateway_op, post_incr] : storage
        CONS ;
        # [pre_incr, gateway_op, post_incr] : storage
        PAIR
      }
      { IF_LEFT
          { # on_result(bytes): store received bytes, increment counter
            # Stack: bytes : storage
            SOME ;
            # (Some bytes) : storage
            # Update %result field:
            #   storage = Pair(count, Pair(dest, Pair(sig, Pair(params, _))))
            #   new     = Pair(count, Pair(dest, Pair(sig, Pair(params, Some bytes))))
            SWAP ; UNPAIR ; SWAP ;
            # config : count : (Some bytes)
            UNPAIR ; SWAP ;
            # rest : dest : count : (Some bytes)
            UNPAIR ; SWAP ;
            # inner : sig : dest : count : (Some bytes)
            CAR ;
            # params : sig : dest : count : (Some bytes)
            DIG 4 ;
            # (Some bytes) : params : sig : dest : count
            SWAP ; PAIR ;
            # Pair(params, Some bytes) : sig : dest : count
            SWAP ; PAIR ;
            # Pair(sig, Pair(params, Some bytes)) : dest : count
            SWAP ; PAIR ;
            # Pair(dest, ...) : count
            SWAP ;
            # count : config'
            PUSH nat 1 ; ADD ;
            # count+1 : config'
            PAIR ;
            # storage'
            NIL operation ; PAIR
          }
          { # _incrementWitness()
            DROP ;
            UNPAIR ; PUSH nat 1 ; ADD ; PAIR ;
            NIL operation ; PAIR
          }
      }
  } ;
