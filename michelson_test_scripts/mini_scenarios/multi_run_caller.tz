parameter
  (or (unit %run)
      (or (unit %_incrementWitness) (unit %_revert))) ;
storage (pair (nat %count) (pair (bool %willRevert) (list %callees address))) ;
# Calls %run on a configurable list of callees.
#
# %run iterates over a list of callees. For each callee, it increments
# count then calls callee %run with Unit and 0 mutez. Each callee must
# expose a parameterless %run entrypoint. After all callees, the contract
# fails if willRevert is true, otherwise increments count one last time.
#
# %run builds and emits a flat list of operations:
#   [incr, callee_1.run, incr, callee_2.run, ..., incr_or_revert]
#
# %_incrementWitness: count++
# %_revert: FAILWITH
#
# The count witness allows tests to verify exactly which parts of the
# call tree executed and which were reverted.
#
# Since this contract itself exposes %run, it can be composed with
# itself and with cross_runtime_run_evm.tz, cross_runtime_run_tez.sol
# and multi_run_caller.sol to build arbitrary cross-runtime call trees.
#
# EVM counterpart: multi_run_caller.sol (with catch support).
code
  { UNPAIR ;
    IF_LEFT
      { # run()
        DROP ;
        DUP ; CDR ; CDR ;
        # callees : storage
        # Reverse callees so that forward ITER + CONS yields correct order
        NIL address ; SWAP ; ITER { CONS } ;
        # reversed_callees : storage
        # Build final operation: _incrementWitness or _revert
        DIP { DUP ; CDR ; CAR } ;
        # reversed_callees : willRevert : storage
        DIP
          { IF
              { SELF %_revert ;
                PUSH mutez 0 ; UNIT ; TRANSFER_TOKENS }
              { SELF %_incrementWitness ;
                PUSH mutez 0 ; UNIT ; TRANSFER_TOKENS }
          } ;
        # reversed_callees : final_op : storage
        # Start accumulator with [final_op]
        DIP { NIL operation ; SWAP ; CONS } ;
        # reversed_callees : [final_op] : storage
        # For each callee: CONS callee.run, then CONS _incrementWitness
        ITER
          { # callee : ops : storage
            CONTRACT %run unit ; ASSERT_SOME ;
            PUSH mutez 0 ; UNIT ; TRANSFER_TOKENS ;
            CONS ;
            # [callee.run, ...ops] : storage
            DIP
              { SELF %_incrementWitness ;
                PUSH mutez 0 ; UNIT ; TRANSFER_TOKENS } ;
            # [callee.run, ...ops] : incr_op : storage
            SWAP ; CONS
            # [incr, callee.run, ...ops] : storage
          } ;
        # ops : storage
        PAIR
      }
      { IF_LEFT
          { # _incrementWitness()
            DROP ;
            UNPAIR ; PUSH nat 1 ; ADD ; PAIR ;
            NIL operation ; PAIR
          }
          { # _revert()
            DROP ; DROP ;
            PUSH string "revert" ; FAILWITH
          }
      }
  } ;
