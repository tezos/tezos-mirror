# UNPACK timestamp on the canonical multi-byte encoding of 12345
# (seconds since the Unix epoch) must succeed. Control case for the
# trailing-zero rejection in unpack_timestamp_01.
code { UNPACK timestamp } ;
input { Stack_elt bytes 0x0500b9c001 } ;
output { Stack_elt (option timestamp) (Some "1970-01-01T03:25:45Z") }
